{
  "version": 2,
  "name": "dogfriend",
  "routes": [
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/share", "dest": "/api/og" },
    { "src": "/admin.html", "dest": "/admin.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/landing.html", "dest": "/landing.html" },
    { "src": "/privacy.html", "dest": "/privacy.html" },
    { "src": "/offer.html", "dest": "/offer.html" },
    { "src": "/terms.html", "dest": "/terms.html" },
    { "src": "/cookie.html", "dest": "/cookie.html" },
    { "src": "/(.*\\.js)", "dest": "/$1" },
    { "src": "/(.*\\.css)", "dest": "/$1" },
    { "src": "/(.*\\.png)", "dest": "/$1" },
    { "src": "/(.*\\.json)", "dest": "/$1" },
    { "src": "/(.*\\.ico)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
