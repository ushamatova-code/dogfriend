{
  "version": 2,
  "name": "dogfriend",
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/(.*\\.js)", "dest": "/$1" },
    { "src": "/(.*\\.css)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
