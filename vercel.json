{
  "version": 2,
  "name": "dogfriend",
  "builds": [
    {
      "src": "api/og.js",
      "use": "@vercel/edge"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/share(.*)", "dest": "/api/og.js" },
    { "src": "/admin.html", "dest": "/admin.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/landing.html", "dest": "/landing.html" },
    { "src": "/(.*\\.js)", "dest": "/$1" },
    { "src": "/(.*\\.css)", "dest": "/$1" },
    { "src": "/(.*\\.png)", "dest": "/$1" },
    { "src": "/(.*\\.json)", "dest": "/$1" },
    { "src": "/(.*\\.ico)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
